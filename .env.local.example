# ── Supabase (from the Vercel↔Supabase integration / Project Settings → API) ─
# The service-role key is server-only — it bypasses RLS; never ship it to the
# browser. The URL and anon key are safe to expose (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgres://...

# ── Anthropic (server-side only — powers SAP↔AB extraction) ─────────────────
# Extraction model is set in code (src/lib/config.ts → ANTHROPIC_MODEL), not here.
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail mailbox integration (Settings → Integrations → Connect) ───────────
# OAuth client from Google Cloud Console (APIs & Services → Credentials →
# OAuth client ID, type "Web application"). Enable the Gmail API, add
#   <origin>/api/mail/connect/google/callback
# as an authorized redirect URI (both localhost and the deployed URL), and add
# your mailbox as a test user on the consent screen. Scopes used:
# gmail.readonly (scan) + gmail.send (pushback/chaser replies).
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# Shared secret guarding the mailbox poll cron (/api/mail/poll) and push
# endpoint. Required for scanning to run — the endpoints fail closed without it.
# Any random string; Vercel cron also accepts it as CRON_SECRET (Bearer).
# MAIL_POLL_SECRET=
# Canonical external URL for OAuth redirects. Normally unset (derived from the
# request); set only behind a proxy that hides host/proto.
# APP_URL=

# ── Optional / add as needed ────────────────────────────────────────────────
# Forwarding address shown in the UI (where suppliers forward ABs).
# INTAKE_EMAIL=ab-intake@example.com
# Shared secret. If set, /api/inbound requires ?secret=... to match.
# INBOUND_WEBHOOK_SECRET=
# Guards /api/seed. Set to any value and pass it as ?token=... to run the seed.
# SEED_TOKEN=dev-seed
# Password for the seeded demo login. Unset = a random password is generated on
# every seed run and printed by `npm run seed`.
# SEED_DEMO_PASSWORD=
# Storage bucket for the original AB PDFs. Optional — code defaults to
# "ab-documents" and auto-creates it on first use. Set only to override.
# SUPABASE_STORAGE_BUCKET=ab-documents
